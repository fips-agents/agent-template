FROM registry.access.redhat.com/ubi9/python-311:latest

ARG PROFILE=minimal

LABEL name="code-sandbox" \
      version="0.5.0" \
      description="Code execution sandbox sidecar (profile: ${PROFILE})" \
      io.openshift.expose-services="8000:http"

# UBI Python images use /opt/app-root as home; src is the conventional app dir
WORKDIR /opt/app-root/src

# Install base deps first for layer caching
COPY --chmod=644 pyproject.toml .
RUN pip install --no-cache-dir "fastapi>=0.115.0" "uvicorn[standard]>=0.32.0" "pyyaml>=6.0"

# Install profile-specific packages (if requirements file exists)
COPY --chmod=644 profiles/${PROFILE}-requirements.txt /tmp/profile-requirements.txt
RUN if [ -s /tmp/profile-requirements.txt ]; then \
        pip install --no-cache-dir -r /tmp/profile-requirements.txt; \
    fi

# Copy source into sandbox/ package directory
COPY --chmod=644 __init__.py app.py executor.py guardrails.py landlock.py \
     pipeline.py profiles.py sandbox/

# Copy profile configs
COPY --chmod=644 profiles/ sandbox/profiles/

ENV SANDBOX_PROFILE=${PROFILE}

EXPOSE 8000

CMD ["uvicorn", "sandbox.app:app", "--host", "0.0.0.0", "--port", "8000"]
